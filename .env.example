# Portas locais do `pnpm dev` (overridáveis; defaults no código/scripts).
# api NestJS (apps/api) — default 4001
API_PORT=4001
# web Next (apps/web) — default 4000
WEB_PORT=4000

# Em produção a API usa PORT (Railway/Render injeta). Local pode ignorar.
# PORT=4001

# Postgres local (docker-compose) ou Neon. Usado a partir da Fatia 1.
DATABASE_URL=postgresql://coach:coach@localhost:5439/coach
