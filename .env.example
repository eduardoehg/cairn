# Local ports for `pnpm dev` (overridable; defaults in code/scripts).
# api NestJS (apps/api) — default 4001
API_PORT=4001
# web Next (apps/web) — default 4000
WEB_PORT=4000

# In production the API uses PORT (injected by Railway/Render). Local can ignore.
# PORT=4001

# Local Postgres (docker-compose) or Neon. Container publishes 5439->5432.
DATABASE_URL=postgresql://coach:coach@localhost:5439/coach
# TLS for managed Postgres (set true on Neon/Render; false for local docker).
DATABASE_SSL=false

# Auth (Fatia 1). Generate strong secrets: `openssl rand -hex 32`
JWT_ACCESS_SECRET=change-me-strong-secret
JWT_REFRESH_SECRET=change-me-another-strong-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Run migrations on boot (true on deploy; locally use `pnpm migration:run`)
RUN_MIGRATIONS=false

# CORS: comma-separated allowed origins (e.g. the Vercel URL in prod).
# Leave empty in local dev to reflect any origin.
CORS_ORIGINS=

# Frontend (apps/web): API base URL. Defaults to http://localhost:4001 in dev;
# set to the Render URL in Vercel for prod.
NEXT_PUBLIC_API_URL=http://localhost:4001
